{
    "name": "__MSG_title__",
    "version": "1.0",
    "manifest_version": 3,
    "default_locale":"en",
    "description": "__MSG_description__",
    "icons": {
        "48": "icon.png"
    },
    "permissions": ["tabs", "activeTab", "scripting", "downloads","sidePanel", "audio"],
    "action": {
        "default_icon": "icon.png"
    },
    "side_panel": { 
        "default_path": "sidebar.html" 
    },
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
        "matches": ["https://*/*"],
        "js": ["content.js"]
        }
    ]
  }